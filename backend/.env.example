# ─────────────────────────────────────────────────────────────
#  Notes Management App — Backend Environment Variables
#  Copy this file to .env and fill in your own values.
#  NEVER commit the real .env file to source control.
# ─────────────────────────────────────────────────────────────

# Server
PORT=5000

# MySQL (match your MySQL Workbench connection settings)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=notes_management_db

# JWT — use a long, random secret in production
JWT_SECRET=change_this_to_a_very_long_random_secret
JWT_EXPIRES_IN=7d
